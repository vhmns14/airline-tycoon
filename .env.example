# Copy to .env and fill in locally. NEVER commit .env
#   cp .env.example .env

PORT=3001

# Long random string (min 16 chars). Required for stable sessions.
JWT_SECRET=

# Optional: create/promote admin on API boot (local only)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Set to 1 only to force-reset admin password from ADMIN_PASSWORD on next boot
# ADMIN_RESET_PASSWORD=1
